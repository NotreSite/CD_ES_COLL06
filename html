  <button onclick="lpRetour()" title="Retour à l'accueil" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.18);color:rgba(255,255,255,0.75);padding:5px 13px;border-radius:5px;cursor:pointer;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;flex-shrink:0;transition:background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.16)'" onmouseout="this.style.background='rgba(255,255,255,0.08)'">← Accueil</button>
  <div>
    <div class="logo">APD <span>2026</span></div>
    <div class="subtitle">Outil d'Aide à la Décision Pédagogique</div>
  </div>
  <div style="flex:1">
    <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:16px;">Course de Durée</div>
    <div style="font-size:11px;color:#aaa;">Module EPS — Collège · Orientations Pédagogiques 2009</div>
  </div>
  <span class="badge-new">Collège</span>
</header>

<!-- ===== MODULE NAV ===== -->
<nav class="module-nav">
  <button class="mnav-btn active" onclick="showModule('mod-apd', this)">
    <span class="mnav-icon">⚡</span> APD — Évaluation
  </button>
  <button class="mnav-btn" onclick="showModule('mod-conduites', this)">
    <span class="mnav-icon">🧭</span> Conduites Typiques
  </button>
  <button class="mnav-btn" onclick="showModule('mod-planif', this)">
    <span class="mnav-icon">📋</span> Planification Pédagogique
  </button>
</nav>

<div class="main-wrap">

<!-- MODULE : APD ÉVALUATION -->
<div id="mod-apd" class="module-panel active">
  <!-- ===== SECTION 1 : CONFIGURATION ===== -->
  <div class="card" style="margin-bottom:22px;">
    <div class="card-header"><span class="step-num">1</span> Configuration de la Séance</div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;">
        <div>
          <label class="field-label">Niveau / Classe</label>
          <select id="cfg-niveau" onchange="updateConfig(); renderBaremeTables();">
            <option value="1ASC">1ère Année Collège (1ASC)</option>
            <option value="2ASC">2ème Année Collège (2ASC)</option>
            <option value="3ASC">3ème Année Collège (3ASC)</option>
          </select>
        </div>
        <div>
          <label class="field-label">Distance Piste (m)</label>
          <input type="number" id="cfg-piste" value="200" min="50" max="500" step="50" onchange="updateConfig()" placeholder="ex: 200"/>
        </div>
        <div>
          <label class="field-label">Date de la Séance</label>
          <input type="date" id="cfg-date"/>
        </div>
        <div>
          <label class="field-label">Séance N°</label>
          <input type="text" id="cfg-seance" placeholder="ex: 3"/>
        </div>
        <div>
          <label class="field-label">Établissement</label>
          <input type="text" id="cfg-etab" placeholder="Nom de l'établissement"/>
        </div>
        <div>
          <label class="field-label">Professeur</label>
          <input type="text" id="cfg-prof" placeholder="Nom du professeur"/>
        </div>
      </div>
      <div style="margin-top:14px;display:flex;gap:20px;flex-wrap:wrap;">
        <div class="info-tip">📏 Distance garçons : <strong id="dist-g">1000 m</strong></div>
        <div class="info-tip">📏 Distance filles : <strong id="dist-f">600 m</strong></div>
        <div class="info-tip">🔄 Tours garçons : <strong id="tours-g">5</strong></div>
        <div class="info-tip">🔄 Tours filles : <strong id="tours-f">3</strong></div>
      </div>
    </div>
  </div>

  <!-- ===== SECTION 2 : SAISIE & BAREMES ===== -->
  <div class="card" style="margin-bottom:22px;">
    <div class="card-header"><span class="step-num">2</span> Saisie des Données & Barèmes</div>
    <div class="card-body">
      <div class="tab-bar">
        <button class="tab-btn active" onclick="switchTab('tab-saisie',this)">✏️ Saisie Manuelle</button>
        <button class="tab-btn" onclick="switchTab('tab-csv',this)">📥 Import CSV</button>
        <button class="tab-btn" onclick="switchTab('tab-bareme',this)">⚙️ Configuration des Barèmes</button>
      </div>

      <!-- TAB : Saisie manuelle -->
      <div id="tab-saisie" class="tab-panel active">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-bottom:16px;padding:16px;background:var(--stripe);border-radius:8px;border:1px solid var(--border);">
          <div>
            <label class="field-label">Nom Prénom</label>
            <input type="text" id="new-nom" placeholder="ex: Ahmed Alaoui"/>
          </div>
          <div>
            <label class="field-label">Sexe</label>
            <select id="new-sexe" onchange="updateNewLapFields()">
              <option value="M">Masculin (M)</option>
              <option value="F">Féminin (F)</option>
            </select>
          </div>
          <div>
            <label class="field-label">VMA (km/h)</label>
            <input type="number" id="new-vma" placeholder="ex: 12.5" step="0.1" min="4" max="25" onchange="updateNewLapFields()"/>
          </div>
          <div>
            <label class="field-label">Statut Cible</label>
            <select id="new-cible">
              <option value="FT">FT — Finit Total (8 pts)</option>
              <option value="FP">FP — Finit Partiel (5 pts)</option>
              <option value="AB">AB — Abandon (2 pts)</option>
            </select>
          </div>
        </div>
        <div style="margin-bottom:14px;">
          <label class="field-label">Temps réels par tour (MM:SS) — <span id="lap-count-label">0 tours</span></label>
          <div id="new-laps-container" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;">
            <span style="color:var(--muted);font-size:12px;">Configurez la piste pour générer les tours</span>
          </div>
        </div>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <div style="flex:1;min-width:200px;">
            <label class="field-label">Temps Total (auto si tours saisis)</label>
            <input type="text" id="new-total-time" placeholder="MM:SS ou auto"/>
          </div>
          <div style="padding-top:20px;">
            <button class="btn btn-primary" onclick="addStudent()">➕ Ajouter l'Élève</button>
          </div>
        </div>
      </div>

      <!-- TAB : CSV -->
      <div id="tab-csv" class="tab-panel">
        <div style="background:var(--stripe);border:1.5px dashed var(--border);border-radius:8px;padding:20px;text-align:center;margin-bottom:14px;">
          <div style="font-size:28px;margin-bottom:8px;">📄</div>
          <div style="font-weight:600;margin-bottom:6px;">Importer un fichier CSV</div>
          <div style="font-size:12px;color:var(--muted);margin-bottom:12px;">Format attendu : Nom, Sexe(M/F), VMA, NotePerf, StatutCible(FT/FP/AB), Temps1, Temps2, ...</div>
          <input type="file" id="csv-file" accept=".csv" onchange="importCSV(event)" style="display:none"/>
          <button class="btn btn-outline" onclick="document.getElementById('csv-file').click()">📂 Choisir un fichier CSV</button>
          <button class="btn btn-outline btn-sm" onclick="downloadCSVTemplate()" style="margin-left:8px;">⬇️ Télécharger le modèle</button>
        </div>
        <div id="csv-feedback" style="font-size:12px;color:var(--green);"></div>
      </div>

      <!-- TAB : BAREMES MODIFIABLES -->
      <div id="tab-bareme" class="tab-panel">
        <p style="font-size:13px;color:var(--muted);margin-bottom:16px;">
          💡 Modifiez directement les seuils ci-dessous (en secondes) pour ajuster les notes du niveau sélectionné (<strong id="bareme-level-title">1ASC</strong>). Les changements s'appliqueront instantanément lors des prochains calculs.
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;">
          <!-- Perf Garçons -->
          <div class="card">
            <div class="card-header" style="background:#1e293b;">🏃‍♂️ Performance Garçons (/6)</div>
            <div class="card-body" style="padding:10px; max-height:300px; overflow-y:auto;">
              <table class="data-table" style="font-size:12px;">
                <thead><tr><th>Note</th><th>Seuil max (MM:SS)</th></tr></thead>
                <tbody id="bareme-perf-m-tbody"></tbody>
              </table>
            </div>
          </div>
          <!-- Perf Filles -->
          <div class="card">
            <div class="card-header" style="background:#1e293b;">🏃‍♀️ Performance Filles (/6)</div>
            <div class="card-body" style="padding:10px; max-height:300px; overflow-y:auto;">
              <table class="data-table" style="font-size:12px;">
                <thead><tr><th>Note</th><th>Seuil max (MM:SS)</th></tr></thead>
                <tbody id="bareme-perf-f-tbody"></tbody>
              </table>
            </div>
          </div>
          <!-- Régularité -->
          <div class="card">
            <div class="card-header" style="background:#1e293b;">⏱️ Régularité (Σ Écarts en sec) (/6)</div>
            <div class="card-body" style="padding:10px; max-height:300px; overflow-y:auto;">
              <table class="data-table" style="font-size:12px;">
                <thead><tr><th>Note</th><th>Σ Écarts max (sec)</th></tr></thead>
                <tbody id="bareme-reg-tbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ===== SECTION 3 : TABLEAU DES ÉLÈVES ===== -->
  <div class="card" style="margin-bottom:22px;">
    <div class="card-header" style="justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:8px;"><span class="step-num">3</span> Liste des Élèves & Scores</div>
      <div style="display:flex;gap:8px;">
        <button class="btn btn-success btn-sm" onclick="computeAll()">⚡ Calculer Tous</button>
        <button class="btn btn-outline btn-sm" onclick="exportCSV()">📤 Exporter CSV</button>
        <button class="btn btn-danger btn-sm" onclick="clearAll()">🗑️ Effacer Tout</button>
      </div>
    </div>
    <div class="card-body" style="padding:0;">
      <div class="overflow-x-auto">
        <table class="data-table" id="students-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Nom / Prénom</th>
              <th>Sexe</th>
              <th>VMA (km/h)</th>
              <th>Tps Cible/Tour</th>
              <th>Tours Réels</th>
              <th>Σ Écarts</th>
              <th>Note Perf /6</th>
              <th>Note Régul. /6</th>
              <th>Note Cible /8</th>
              <th>NOTE /20</th>
              <th>Niveau</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="students-tbody">
            <tr id="empty-row">
              <td colspan="13" style="text-align:center;color:var(--muted);padding:30px;font-style:italic;">
                Aucun élève enregistré. Commencez par ajouter des élèves ci-dessus.
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ===== SECTION 4 : TABLEAU DE BORD ===== -->
  <div id="dashboard" style="display:none;margin-bottom:22px;">
    <div class="section-divider"><span>📊 Tableau de Bord — Statistiques de Classe</span></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-bottom:20px;">
      <div class="stat-card" style="border-top:3px solid var(--accent2);">
        <div class="stat-num" id="stat-total">0</div>
        <div class="stat-label">Élèves total</div>
      </div>
      <div class="stat-card" style="border-top:3px solid #6366f1;">
        <div class="stat-num" id="stat-avg">—</div>
        <div class="stat-label">Moyenne classe /20</div>
      </div>
      <div class="stat-card" style="border-top:3px solid var(--green);">
        <div class="stat-num" id="stat-nA" style="color:var(--green);">0</div>
        <div class="stat-label">Niveau A (>16)</div>
      </div>
      <div class="stat-card" style="border-top:3px solid var(--orange);">
        <div class="stat-num" id="stat-nB" style="color:var(--orange);">0</div>
        <div class="stat-label">Niveau B (11–16)</div>
      </div>
      <div class="stat-card" style="border-top:3px solid var(--red);">
        <div class="stat-num" id="stat-nC" style="color:var(--red);">0</div>
        <div class="stat-label">Niveau C (≤10)</div>
      </div>
      <div class="stat-card" style="border-top:3px solid #0ea5e9;">
        <div class="stat-num" id="stat-success">—</div>
        <div class="stat-label">Taux de réussite</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;">
      <div class="card">
        <div class="card-header">Distribution des Niveaux</div>
        <div class="card-body" style="height:220px;display:flex;align-items:center;justify-content:center;">
          <canvas id="chart-levels" style="max-height:200px;"></canvas>
        </div>
      </div>
      <div class="card">
        <div class="card-header">Distribution des Notes /20</div>
        <div class="card-body" style="height:220px;display:flex;align-items:center;justify-content:center;">
          <canvas id="chart-notes" style="max-height:200px;"></canvas>
        </div>
      </div>
    </div>
  </div>

</div><!-- /.mod-apd -->

<!-- ============================================================ -->
<!-- MODULE : CONDUITES TYPIQUES DES ÉLÈVES                       -->
<!-- ============================================================ -->
<div id="mod-conduites" class="module-panel">

  <div class="section-divider" style="margin-top:8px;"><span>🧭 Conduites Typiques des Élèves — Course de Durée (EPS Maroc 2009)</span></div>

  <!-- Intro -->
  <div class="card" style="margin-bottom:20px;">
    <div class="card-header"><span class="step-num" style="background:var(--accent2);">i</span> Présentation de la Rubrique</div>
    <div class="card-body">
      <p style="font-size:13px;color:var(--muted);line-height:1.7;">
        Cette rubrique présente les <strong>conduites typiques</strong> observées chez les élèves du collège et du lycée en Course de Durée, classées par niveau (<span class="niveau-c">Débutant</span> / <span class="niveau-b">Intermédiaire</span> / <span class="niveau-a">Avancé</span>). Elle couvre quatre domaines : moteur, tactique, méthodologique et social, en cohérence avec les <em>Orientations Pédagogiques marocaines 2007/2009</em>.
      </p>
    </div>
  </div>

  <!-- Level selector -->
  <div class="ct-level-tabs">
    <button class="ct-level-btn debutant active" onclick="ctSwitchLevel('debutant', this)">
      🔴 Niveau Débutant
    </button>
    <button class="ct-level-btn intermediaire" onclick="ctSwitchLevel('intermediaire', this)">
      🟡 Niveau Intermédiaire
    </button>
    <button class="ct-level-btn avance" onclick="ctSwitchLevel('avance', this)">
      🟢 Niveau Avancé
    </button>
  </div>

  <!-- ======= DÉBUTANT ======= -->
  <div id="ct-debutant" class="ct-panel active">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <span class="niveau-c" style="font-size:14px;padding:4px 14px;">Niveau Débutant — Note ≤ 10/20</span>
      <span style="font-size:12px;color:var(--muted);">Profil observé en début de cycle ou chez les élèves non pratiquants</span>
    </div>

    <!-- Moteur -->
    <div class="ct-domain-card">
      <div class="ct-domain-header moteur">🏃 Domaine Moteur</div>
      <div class="ct-domain-body">
        <div class="ct-trait-row">
          <div class="ct-trait-box observed">
            <div class="ct-trait-label">Conduites observées</div>
            <div><span class="ct-tag blue">Départ en sprint</span> <span class="ct-tag blue">Allure anarchique</span> <span class="ct-tag blue">Arrêts fréquents</span> <span class="ct-tag blue">Marche avant la fin</span> <span class="ct-tag blue">Respiration saccadée</span> <span class="ct-tag blue">Posture rigide</span></div>
          </div>
          <div class="ct-trait-box difficulty">
            <div class="ct-trait-label">Difficultés principales</div>
            <div><span class="ct-tag orange">Gestion de l'effort</span> <span class="ct-tag orange">Régulation de l'allure</span> <span class="ct-tag orange">Tolérance à l'inconfort</span> <span class="ct-tag orange">Contrôle respiratoire</span></div>
          </div>
        </div>
        <div class="ct-trait-box need" style="margin-top:6px;">
          <div class="ct-trait-label">Besoins d'apprentissage</div>
          Apprendre à courir lentement et régulièrement · Distinguer effort modéré et épuisement · Utiliser le bip sonore comme régulateur d'allure
        </div>
      </div>
    </div>

    <!-- Tactique -->
    <div class="ct-domain-card">
      <div class="ct-domain-header tactique">♟️ Domaine Tactique</div>
      <div class="ct-domain-body">
        <div class="ct-trait-row">
          <div class="ct-trait-box observed">
            <div class="ct-trait-label">Conduites observées</div>
            <div><span class="ct-tag purple">Pas de projet de course</span> <span class="ct-tag purple">Réaction aux autres élèves</span> <span class="ct-tag purple">Cible non choisie</span> <span class="ct-tag purple">Aucune gestion des tours</span></div>
          </div>
          <div class="ct-trait-box difficulty">
            <div class="ct-trait-label">Difficultés principales</div>
            <div><span class="ct-tag orange">Anticipation</span> <span class="ct-tag orange">Choix de la VMA cible</span> <span class="ct-tag orange">Pilotage interne de l'effort</span></div>
          </div>
        </div>
        <div class="ct-trait-box need" style="margin-top:6px;">
          <div class="ct-trait-label">Besoins d'apprentissage</div>
          Construire un projet de course simple · Choisir une allure cible en relation avec sa VMA · Comprendre la notion de régularité
        </div>
      </div>
    </div>

    <!-- Méthodologique -->
    <div class="ct-domain-card">
      <div class="ct-domain-header methodologique">📐 Domaine Méthodologique</div>
      <div class="ct-domain-body">
        <div class="ct-trait-row">
          <div class="ct-trait-box observed">
            <div class="ct-trait-label">Conduites observées</div>
            <div><span class="ct-tag teal">Ignore les temps de tour</span> <span class="ct-tag teal">N'utilise pas la montre</span> <span class="ct-tag teal">Ne connaît pas sa VMA</span> <span class="ct-tag teal">Pas d'auto-évaluation</span></div>
          </div>
          <div class="ct-trait-box difficulty">
            <div class="ct-trait-label">Difficultés principales</div>
            <div><span class="ct-tag orange">Lecture des données</span> <span class="ct-tag orange">Mesure de l'effort</span> <span class="ct-tag orange">Connaissance de soi</span></div>
          </div>
        </div>
        <div class="ct-trait-box need" style="margin-top:6px;">
          <div class="ct-trait-label">Besoins d'apprentissage</div>
          Lire et utiliser sa fiche de course · Connaître et interpréter sa VMA · S'auto-évaluer après chaque tour
        </div>
      </div>
    </div>

    <!-- Social -->
    <div class="ct-domain-card">
      <div class="ct-domain-header social">🤝 Domaine Social</div>
      <div class="ct-domain-body">
        <div class="ct-trait-row">
          <div class="ct-trait-box observed">
            <div class="ct-trait-label">Conduites observées</div>
            <div><span class="ct-tag teal">Course en groupe non structuré</span> <span class="ct-tag teal">Abandon face au groupe</span> <span class="ct-tag teal">Rôle d'observateur refusé</span></div>
          </div>
          <div class="ct-trait-box difficulty">
            <div class="ct-trait-label">Difficultés principales</div>
            <div><span class="ct-tag orange">Coopération</span> <span class="ct-tag orange">Rôle de chronométreur</span> <span class="ct-tag orange">Respect des règles</span></div>
          </div>
        </div>
        <div class="ct-trait-box need" style="margin-top:6px;">
          <div class="ct-trait-label">Besoins d'apprentissage</div>
          Accepter les rôles sociaux (observateur, chronométreur) · Collaborer avec un partenaire de course
        </div>
      </div>
    </div>

    <!-- Besoins synthèse -->
    <div class="section-divider"><span>🎯 Synthèse des Besoins — Niveau Débutant</span></div>
    <div class="needs-grid">
      <div class="need-card" style="border-top-color:#c8402a;">
        <h4 style="color:#c8402a;">🏃 Moteur</h4>
        <ul><li>Stabiliser l'allure sur 2 tours</li><li>Courir sans s'arrêter 6 min</li><li>Contrôler la respiration</li></ul>
      </div>
      <div class="need-card" style="border-top-color:#7c3aed;">
        <h4 style="color:#7c3aed;">♟️ Tactique</h4>
        <ul><li>Formuler un projet de course</li><li>Choisir et tenir une allure</li><li>Adapter la cible à la VMA</li></ul>
      </div>
      <div class="need-card" style="border-top-color:var(--green);">
        <h4 style="color:var(--green);">📐 Méthodologique</h4>
        <ul><li>Lire sa fiche de résultats</li><li>Interpréter les écarts de tour</li><li>Connaître sa VMA de base</li></ul>
      </div>
      <div class="need-card" style="border-top-color:#0891b2;">
        <h4 style="color:#0891b2;">🤝 Social</h4>
        <ul><li>Jouer les rôles définis</li><li>Respecter le parcours</li><li>Soutenir les partenaires</li></ul>
      </div>
    </div>
  </div>

  <!-- ======= INTERMÉDIAIRE ======= -->
  <div id="ct-intermediaire" class="ct-panel">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <span class="niveau-b" style="font-size:14px;padding:4px 14px;">Niveau Intermédiaire — Note 11–16/20</span>
      <span style="font-size:12px;color:var(--muted);">Profil observé en milieu de cycle, acquis partiels</span>
    </div>
    <div class="ct-domain-card">
      <div class="ct-domain-header moteur">🏃 Domaine Moteur</div>
      <div class="ct-domain-body">
        <div class="ct-trait-row">
          <div class="ct-trait-box observed">
            <div class="ct-trait-label">Conduites observées</div>
            <div><span class="ct-tag blue">Allure tenue 3–4 tours</span> <span class="ct-tag blue">Décélération en fin de course</span> <span class="ct-tag blue">Légère irrégularité des temps de tour</span> <span class="ct-tag blue">Récupération partielle entre les tours</span></div>
          </div>
