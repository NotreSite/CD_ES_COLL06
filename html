// Export CSV du cycle complet
function exportCycleCSV() {
  const niveauVal = document.getElementById('plan-niveau').value;
  const duree = document.getElementById('plan-duree').value;
  const nbSeances = document.getElementById('plan-nb-seances').value;
  const freq = document.getElementById('plan-freq').value;

  const isLycee = ['TC','1BAC','2BAC'].includes(niveauVal);
  const planning = distribuerSeances(parseInt(nbSeances), isLycee);

  const rows = [
    ['N°','Phase','Titre','Objectif','Contenu','Organisation','Évaluation','Différenciation'],
    ...planning.map(s => [
      s.num, s.phase, s.titre, s.objectif, s.contenu, s.organisation, s.eval, s.diff
    ])
  ];
  const csv = rows.map(r => r.map(c => '"' + String(c).replace(/"/g, '""') + '"').join(',')).join('\n');
  const blob = new Blob(['\uFEFF' + csv], {type:'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `Projet_Cycle_CoursDuree_${niveauVal}_${nbSeances}seances.csv`;
  a.click();
}

function exportFichesPDF() {
  exportCycleCSV(); // même export pour l'instant
}

