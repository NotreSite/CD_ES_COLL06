function updateConfig() {
  const cfg = getConfig();
  const toursG = Math.round(DIST_G / cfg.piste);
  const toursF = Math.round(DIST_F / cfg.piste);
  document.getElementById('dist-g').textContent = DIST_G + ' m';
  document.getElementById('dist-f').textContent = DIST_F + ' m';
  document.getElementById('tours-g').textContent = toursG;
  document.getElementById('tours-f').textContent = toursF;
  document.getElementById('bareme-level-title').textContent = cfg.niveau;
  updateNewLapFields();
}

function renderBaremeTables() {
  const cfg = getConfig();
  
  // Render Perf M
  const tbodyPM = document.getElementById('bareme-perf-m-tbody');
  tbodyPM.innerHTML = '';
  PERF_SCALES[cfg.niveau].M.forEach((row, i) => {
    tbodyPM.innerHTML += `<tr>
      <td style="font-weight:bold;">${row[1].toFixed(1)}</td>
      <td><input type="text" value="${formatTime(row[0])}" onchange="updatePerfThreshold('${cfg.niveau}', 'M', ${i}, this.value)" style="padding:2px 6px; font-size:12px;"/></td>
    </tr>`;
  });

  // Render Perf F
  const tbodyPF = document.getElementById('bareme-perf-f-tbody');
  tbodyPF.innerHTML = '';
  PERF_SCALES[cfg.niveau].F.forEach((row, i) => {
    tbodyPF.innerHTML += `<tr>
      <td style="font-weight:bold;">${row[1].toFixed(1)}</td>
      <td><input type="text" value="${formatTime(row[0])}" onchange="updatePerfThreshold('${cfg.niveau}', 'F', ${i}, this.value)" style="padding:2px 6px; font-size:12px;"/></td>
    </tr>`;
  });

  // Render Régularité
  const tbodyR = document.getElementById('bareme-reg-tbody');
  tbodyR.innerHTML = '';
  REG_SCALES[cfg.niveau].forEach((row, i) => {
    const valueDisp = row[0] === Infinity ? 'Infini' : row[0];
    tbodyR.innerHTML += `<tr>
      <td style="font-weight:bold;">${row[1].toFixed(1)}</td>
      <td><input type="number" value="${row[0]}" ${row[0] === Infinity ? 'readonly' : ''} onchange="updateRegThreshold('${cfg.niveau}', ${i}, this.value)" style="padding:2px 6px; font-size:12px;"/></td>
    </tr>`;
  });
}

function updatePerfThreshold(niv, sexe, index, valString) {
  const sec = parseTime(valString);
  if (sec !== null && !isNaN(sec)) {
    PERF_SCALES[niv][sexe][index][0] = sec;
    renderTable();
  }
}

function updateRegThreshold(niv, index, valNum) {
  const val = parseFloat(valNum);
  if (!isNaN(val)) {
    REG_SCALES[niv][index][0] = val;
    renderTable();
  }
}

function updateNewLapFields() {
  const cfg = getConfig();
  const sexe = document.getElementById('new-sexe').value;
  const dist = sexe === 'M' ? DIST_G : DIST_F;
  const tours = Math.round(dist / cfg.piste);
  document.getElementById('lap-count-label').textContent = tours + ' tour(s)';
  const cont = document.getElementById('new-laps-container');
  cont.innerHTML = '';
  for (let i = 1; i <= tours; i++) {
    const wrap = document.createElement('div');
    wrap.style = 'display:flex; flex-direction:column; align-items:center; gap:2px;';
