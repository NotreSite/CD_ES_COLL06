// --- Moteur principal de génération ---
function genererCycle() {
  const niveauVal = document.getElementById('plan-niveau').value;
  const nbSeances = parseInt(document.getElementById('plan-nb-seances').value);
  const freq = parseInt(document.getElementById('plan-freq').value);
  const duree = parseInt(document.getElementById('plan-duree').value);
  const piste = parseInt(document.getElementById('plan-piste').value);

  const isLycee = ['TC','1BAC','2BAC'].includes(niveauVal);
  const profil = isLycee ? PLAN_DATA.lycee : PLAN_DATA.college;
  const nbSemaines = Math.round(nbSeances / freq);

  // Afficher le résumé
  const resumeEl = document.getElementById('plan-resume');
  const pill = isLycee ? 'plan-pill lycee' : 'plan-pill college';
  resumeEl.innerHTML = `
    <div class="info-tip">📚 <strong>${niveauVal}</strong></div>
    <div class="info-tip">📅 <strong>${nbSeances} séances</strong> · ${nbSemaines} semaines</div>
    <div class="info-tip">⏱️ <strong>${duree} min</strong>/séance</div>
    <div class="info-tip">🏃 Piste <strong>${piste} m</strong></div>
    <div class="info-tip">🎯 VMA cible : <strong>${profil.vmaBase}–${profil.vmaMax} %</strong></div>
  `;

  // Générer le planning des séances
  const planning = distribuerSeances(nbSeances, isLycee);

  // Construire le HTML
  const out = document.getElementById('plan-output');
  out.innerHTML = buildCompetencesHTML(profil, niveauVal) +
    buildChronogrammeHTML(planning, nbSeances, niveauVal, nbSemaines, freq, isLycee) +
    buildSeancesDetaillees(planning, duree, niveauVal, isLycee) +
    buildIndicateursHTML(profil) +
    buildExportButtons(planning, niveauVal, nbSeances, duree);
}

// Distribuer les séances intelligemment selon le nb total
function distribuerSeances(total, isLycee) {
  // Règles de distribution : diag=1-2, eval=1-2(+1 si total>=8), reste=acq+renf
  let nDiag = total <= 5 ? 1 : 2;
  let nEval = total <= 5 ? 1 : total <= 8 ? 2 : 3;
  let nMiddle = total - nDiag - nEval;

  // Répartition acq/renf selon la taille
  let nAcq, nRenf;
  if (nMiddle <= 2) { nAcq = nMiddle; nRenf = 0; }
  else if (nMiddle <= 4) { nAcq = Math.ceil(nMiddle * 0.6); nRenf = nMiddle - nAcq; }
  else { nAcq = Math.ceil(nMiddle * 0.5); nRenf = nMiddle - nAcq; }

  const planning = [];
  let diagPool = [...SEANCE_POOL.diag];
  let acqPool = [...SEANCE_POOL.acq];
  let renfPool = [...SEANCE_POOL.renf];
  let evalPool = [...SEANCE_POOL.eval];

  // Pour lycée : adapter les contenus
  function adaptLycee(s) {
    if (!isLycee) return s;
    return Object.assign({}, s, {
      contenu: s.contenu.replace('VMA 70', 'VMA 80').replace('VMA 70–80', 'VMA 80–85').replace('≤ 15 sec', '≤ 8 sec'),
      eval: s.eval.replace('≤ 15 sec', '≤ 8 sec').replace('≤ 12 sec', '≤ 8 sec')
    });
  }

  for (let i = 0; i < nDiag; i++) {
    planning.push(adaptLycee(diagPool[i % diagPool.length]));
  }
  for (let i = 0; i < nAcq; i++) {
    planning.push(adaptLycee(acqPool[i % acqPool.length]));
  }
  for (let i = 0; i < nRenf; i++) {
    planning.push(adaptLycee(renfPool[i % renfPool.length]));
  }
  for (let i = 0; i < nEval; i++) {
    planning.push(adaptLycee(evalPool[i % evalPool.length]));
  }

  // Numéroter
  return planning.map((s, i) => Object.assign({}, s, { num: i + 1 }));
}

