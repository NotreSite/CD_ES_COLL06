<script>
// ── OUVRIR LA PLATEFORME ──
function ouvrirPlateforme(e) {
  // Fonctionne que les fichiers soient dans le même dossier ou non
  // On laisse le comportement href normal (navigation directe)
  // Si vous êtes dans Claude.ai, téléchargez les deux fichiers dans le même dossier
}

// ── FEATURE CARD MOUSE GLOW ──
function trackMouse(e, el) {
  const r = el.getBoundingClientRect();
  const x = ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%';
  const y = ((e.clientY - r.top) / r.height * 100).toFixed(1) + '%';
  el.style.setProperty('--mx', x);
  el.style.setProperty('--my', y);
}

// ── PARTICLES ──
const pContainer = document.getElementById('particles');
function spawnParticle() {
  const p = document.createElement('div');
  p.className = 'particle';
  const size = Math.random() * 3 + 1;
  const left = Math.random() * 100;
  const dur = Math.random() * 12 + 8;
  const delay = Math.random() * 6;
  p.style.cssText = `width:${size}px;height:${size}px;left:${left}%;bottom:0;animation-duration:${dur}s;animation-delay:${delay}s;`;
  pContainer.appendChild(p);
  setTimeout(() => { if (p.parentNode) p.remove(); }, (dur + delay) * 1000 + 500);
}
for (let i = 0; i < 30; i++) spawnParticle();
setInterval(spawnParticle, 600);

// ── REVEAL ON SCROLL ──
const reveals = document.querySelectorAll('.reveal');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.12 });
reveals.forEach(r => obs.observe(r));

// ── ANIMATED COUNTERS ──
function animCounter(el, target, suffix) {
  let current = 0;
  const step = target / 60;
  const timer = setInterval(() => {
    current = Math.min(current + step, target);
    el.textContent = Math.round(current) + (suffix || '');
    if (current >= target) clearInterval(timer);
  }, 25);
}
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const el = e.target;
      animCounter(el, +el.dataset.target, el.dataset.suffix || '');
      counterObs.unobserve(el);
    }
  });
}, { threshold: 0.5 });
document.querySelectorAll('.stat-num[data-target]').forEach(el => counterObs.observe(el));

// ── LIVE PREVIEW PANEL ──
const liveObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    let n = 0;
    const timer = setInterval(() => {
      n = Math.min(n + 1, 28);
      const totalEl = document.getElementById('vs-total');
      const avgEl   = document.getElementById('vs-avg');
      const aEl     = document.getElementById('vs-a');
      const bEl     = document.getElementById('vs-b');
      if (totalEl) totalEl.textContent = n;
      if (avgEl)   avgEl.textContent = (12.4 + n * 0.02).toFixed(1);
      if (aEl)     aEl.textContent = Math.floor(n * 0.28);
      if (bEl)     bEl.textContent = Math.floor(n * 0.46);
      if (n >= 28) clearInterval(timer);
    }, 60);
    document.querySelectorAll('.mini-bar-fill').forEach(bar => {
      setTimeout(() => { bar.style.width = bar.dataset.w + '%'; }, 300);
    });
    liveObs.unobserve(e.target);
  });
}, { threshold: 0.3 });
const whyVis = document.querySelector('.why-visual');
if (whyVis) liveObs.observe(whyVis);

// ── APS TRACK ──
const apsData = [
  { emoji: '🏃', name: 'Course de Durée',   cat: 'Athlétisme' },
  { emoji: '⚽', name: 'Football',           cat: 'Sports collectifs' },
  { emoji: '🏐', name: 'Volley-ball',        cat: 'Sports collectifs' },
  { emoji: '🏀', name: 'Basket-ball',        cat: 'Sports collectifs' },
  { emoji: '🤸', name: 'Gymnastique',        cat: 'Activités gymniques' },
  { emoji: '🏊', name: 'Natation',           cat: 'Activités aquatiques' },
  { emoji: '🎾', name: 'Tennis de table',    cat: 'Sports de raquette' },
  { emoji: '🏋️', name: 'Haltérophilie',     cat: 'Sports de force' },
  { emoji: '🤼', name: 'Lutte',              cat: 'Arts martiaux' },
  { emoji: '🥊', name: 'Boxe',              cat: 'Arts martiaux' },
  { emoji: '💨', name: 'Course de vitesse',  cat: 'Athlétisme' },
  { emoji: '🦘', name: 'Saut en longueur',   cat: 'Athlétisme' },
  { emoji: '🎽', name: 'Cross-country',      cat: 'Athlétisme' },
  { emoji: '🤾', name: 'Handball',           cat: 'Sports collectifs' },
  { emoji: '🎯', name: 'Lancer du javelot',  cat: 'Athlétisme' },
];
const track = document.getElementById('aps-track');
if (track) {
  const doubled = [...apsData, ...apsData];
  doubled.forEach(a => {
    const card = document.createElement('div');
    card.className = 'aps-card';
    card.innerHTML = `<span class="aps-emoji">${a.emoji}</span><div class="aps-name">${a.name}</div><div class="aps-cat">${a.cat}</div>`;
    track.appendChild(card);
  });
}

// ── SMOOTH SCROLL for anchor links ──
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const target = document.querySelector(a.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth' });
  });
});

// ── PARALLAX HERO ──
window.addEventListener('scroll', () => {
  const y = window.scrollY;
  const heroContent = document.querySelector('.hero-content');
  const orbital = document.querySelector('.orbital-container');
  if (heroContent) heroContent.style.transform = `translateY(${y * 0.25}px)`;
  if (orbital) orbital.style.transform = `translate(-50%,-50%) rotate(${y * 0.02}deg)`;
});
</script>

