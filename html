<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>APD 2026 — Course de Durée | Collège</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0f1117;
    --paper: #f5f3ef;
    --accent: #c8402a;
    --accent2: #2a6ac8;
    --green: #1a7a4a;
    --orange: #d97706;
    --red: #c8402a;
    --border: #d4cfc7;
    --muted: #7a7568;
    --card: #ffffff;
    --stripe: #f9f7f4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-size: 14px;
    line-height: 1.6;
  }
  h1,h2,h3,h4,.font-display { font-family: 'Syne', sans-serif; }

  /* Header */
  .app-header {
    background: var(--ink);
    color: white;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
    border-bottom: 3px solid var(--accent);
  }
  .app-header .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.5px;
  }
  .app-header .logo span { color: var(--accent); }
  .app-header .subtitle {
    font-size: 11px;
    color: #aaa;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .badge-new {
    background: var(--accent);
    color: white;
    font-size: 9px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 3px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Layout */
  .main-wrap { max-width: 1400px; margin: 0 auto; padding: 28px 24px; }

  /* Cards */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .card-header {
    background: var(--ink);
    color: white;
    padding: 12px 20px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .card-body { padding: 20px; }
  .card-header .step-num {
    background: var(--accent);
    color: white;
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
    flex-shrink: 0;
  }

  /* Form controls */
  label.field-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 5px;
  }
  input[type=text], input[type=number], input[type=date], select, textarea {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    padding: 8px 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--ink);
    background: white;
    outline: none;
    transition: border-color 0.15s;
  }
  input:focus, select:focus { border-color: var(--accent2); box-shadow: 0 0 0 3px rgba(42,106,200,0.1); }
  input[readonly] { background: var(--stripe); color: var(--muted); }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 18px; border-radius: 6px; border: none; cursor: pointer;
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.5px; text-transform: uppercase; transition: all 0.15s;
  }
  .btn-primary { background: var(--accent2); color: white; }
  .btn-primary:hover { background: #1e55a8; }
  .btn-danger { background: var(--accent); color: white; }
  .btn-danger:hover { background: #a83020; }
  .btn-success { background: var(--green); color: white; }
  .btn-success:hover { background: #145e38; }
  .btn-outline {
    background: transparent; border: 1.5px solid var(--border);
    color: var(--ink);
  }
  .btn-outline:hover { border-color: var(--accent2); color: var(--accent2); }
  .btn-sm { padding: 6px 12px; font-size: 11px; }

  /* Table */
  .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .data-table th {
    background: var(--ink); color: white;
    padding: 10px 10px; text-align: left;
    font-family: 'Syne', sans-serif; font-weight: 600;
    font-size: 11px; letter-spacing: 0.8px; text-transform: uppercase;
    white-space: nowrap;
  }
  .data-table td {
    padding: 9px 10px; border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .data-table tr:nth-child(even) td { background: var(--stripe); }
  .data-table tr:hover td { background: #ede9e2; }
  .data-table input[type=text], .data-table input[type=number] {
    padding: 5px 7px; font-size: 12px; min-width: 55px;
  }

  /* Profile badges */
  .niveau-a { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; border-radius: 5px; padding: 2px 9px; font-weight: 700; font-size: 12px; }
  .niveau-b { background: #fef3c7; color: #92400e; border: 1px solid #fcd34d; border-radius: 5px; padding: 2px 9px; font-weight: 700; font-size: 12px; }
  .niveau-c { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; border-radius: 5px; padding: 2px 9px; font-weight: 700; font-size: 12px; }

  /* Stats cards */
  .stat-card {
    background: white; border: 1px solid var(--border); border-radius: 8px;
    padding: 16px 20px;
  }
  .stat-num { font-family: 'Syne', sans-serif; font-size: 28px; font-weight: 800; }
  .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(15,17,23,0.75);
    z-index: 1000; display: flex; align-items: center; justify-content: center;
    padding: 20px; backdrop-filter: blur(3px);
    opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .modal-overlay.active { opacity: 1; pointer-events: all; }
  .modal-box {
    background: white; border-radius: 14px; max-width: 820px; width: 100%;
    max-height: 88vh; overflow-y: auto;
    box-shadow: 0 25px 60px rgba(0,0,0,0.35);
    transform: translateY(20px); transition: transform 0.2s;
  }
  .modal-overlay.active .modal-box { transform: translateY(0); }
  .modal-header {
    background: var(--ink); color: white; padding: 18px 24px;
    display: flex; align-items: center; justify-content: space-between;
    border-radius: 14px 14px 0 0;
  }
  .modal-body { padding: 24px; }
  .close-btn { background: none; border: none; color: #aaa; cursor: pointer; font-size: 22px; line-height: 1; }
  .close-btn:hover { color: white; }

  /* Divider */
  .section-divider {
    display: flex; align-items: center; gap: 14px;
    margin: 28px 0 20px;
  }
  .section-divider span {
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px;
    white-space: nowrap;
  }
  .section-divider::before, .section-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  /* Lap time input */
  .lap-input { width: 75px !important; min-width: 75px !important; text-align: center; font-size: 12px; }
  
  /* Diagnostic box */
  .diag-box {
    border-left: 3px solid var(--accent2);
    background: #f0f5ff; border-radius: 0 6px 6px 0;
    padding: 12px 16px; margin-bottom: 12px; font-size: 13px;
  }
  .rem-box {
    border-left: 3px solid var(--green);
    background: #f0faf5; border-radius: 0 6px 6px 0;
    padding: 12px 16px; font-size: 13px;
  }
  .rem-box ul { margin-top: 6px; padding-left: 18px; }
  .rem-box li { margin-bottom: 4px; }

  /* Radio group */
  .radio-group { display: flex; gap: 8px; flex-wrap: wrap; }
  .radio-opt {
    flex: 1; min-width: 80px;
    border: 2px solid var(--border); border-radius: 7px;
    padding: 8px 10px; cursor: pointer; text-align: center;
    transition: all 0.15s; font-size: 12px; font-weight: 600;
    background: white;
  }
  .radio-opt input { display: none; }
  .radio-opt:has(input:checked) { border-color: var(--accent2); background: #f0f5ff; }
  .radio-opt .opt-score { font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800; color: var(--accent2); }

  /* Score display */
  .score-display {
    font-family: 'Syne', sans-serif; font-weight: 800;
    font-size: 18px; color: var(--accent2);
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--stripe); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* Tabs */
  .tab-bar { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 20px; }
  .tab-btn {
    padding: 10px 20px; border: none; background: none; cursor: pointer;
    font-family: 'Syne', sans-serif; font-weight: 600; font-size: 12px;
    letter-spacing: 0.5px; text-transform: uppercase; color: var(--muted);
    border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.15s;
  }
  .tab-btn.active { color: var(--accent2); border-bottom-color: var(--accent2); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* Tooltip note */
  .info-tip {
    display: inline-block; background: var(--stripe); border: 1px solid var(--border);
    border-radius: 5px; padding: 6px 12px; font-size: 11px; color: var(--muted);
    margin-top: 6px;
  }
  
  .overflow-x-auto { overflow-x: auto; }
  select option { font-size: 13px; }
  
  @media (max-width: 768px) {
    .main-wrap { padding: 16px 12px; }
    .app-header { padding: 14px 16px; flex-wrap: wrap; }
    .stat-num { font-size: 22px; }
  }

  /* ===== MODULE NAV ===== */
  .module-nav {
    background: #1a1e2b;
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--accent);
    overflow-x: auto;
  }
  .mnav-btn {
    display: flex; align-items: center; gap: 7px;
    padding: 13px 22px;
    background: none; border: none; cursor: pointer;
    font-family: 'Syne', sans-serif; font-weight: 600; font-size: 12px;
    letter-spacing: 0.7px; text-transform: uppercase;
    color: #888; border-bottom: 3px solid transparent;
    margin-bottom: -2px; white-space: nowrap;
    transition: all 0.18s;
  }
  .mnav-btn:hover { color: #ccc; }
  .mnav-btn.active { color: white; border-bottom-color: var(--accent); background: rgba(200,64,42,0.07); }
  .mnav-icon { font-size: 15px; }

  /* ===== MODULE PANELS ===== */
  .module-panel { display: none; }
  .module-panel.active { display: block; }

  /* ===== CONDUITES TYPIQUES ===== */
  .ct-level-tabs { display: flex; gap: 10px; margin-bottom: 22px; flex-wrap: wrap; }
  .ct-level-btn {
    padding: 9px 22px; border-radius: 7px; border: 2px solid var(--border);
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer;
    background: white; transition: all 0.18s;
  }
  .ct-level-btn.debutant.active { background: #fee2e2; border-color: #fca5a5; color: #991b1b; }
  .ct-level-btn.intermediaire.active { background: #fef3c7; border-color: #fcd34d; color: #92400e; }
  .ct-level-btn.avance.active { background: #d1fae5; border-color: #6ee7b7; color: #065f46; }
  .ct-level-btn:not(.active):hover { border-color: var(--accent2); }
  .ct-panel { display: none; }
  .ct-panel.active { display: block; }

  .ct-domain-card {
    border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 16px;
  }
  .ct-domain-header {
    padding: 11px 18px; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 12px;
    letter-spacing: 0.8px; text-transform: uppercase; display: flex; align-items: center; gap: 9px;
    color: white;
  }
  .ct-domain-header.moteur { background: #1d4ed8; }
  .ct-domain-header.tactique { background: #7c3aed; }
  .ct-domain-header.methodologique { background: var(--green); }
  .ct-domain-header.social { background: #0891b2; }
  .ct-domain-body { padding: 16px 18px; background: white; }

  .ct-trait-row {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 12px; margin-bottom: 10px;
  }
  .ct-trait-box {
    border-radius: 7px; padding: 11px 14px; font-size: 13px;
  }
  .ct-trait-box.observed { background: #f0f5ff; border-left: 3px solid var(--accent2); }
  .ct-trait-box.difficulty { background: #fff7ed; border-left: 3px solid var(--orange); }
  .ct-trait-box.need { background: #f0fdf4; border-left: 3px solid var(--green); }
  .ct-trait-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase;
    color: var(--muted); margin-bottom: 5px;
  }
  .ct-tag {
    display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600;
    margin: 2px 2px 2px 0;
  }
  .ct-tag.red { background: #fee2e2; color: #991b1b; }
  .ct-tag.orange { background: #fef3c7; color: #92400e; }
  .ct-tag.green { background: #d1fae5; color: #065f46; }
  .ct-tag.blue { background: #dbeafe; color: #1e40af; }
  .ct-tag.purple { background: #ede9fe; color: #5b21b6; }
  .ct-tag.teal { background: #cffafe; color: #0e7490; }

  .needs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 12px; margin-top: 16px; }
  .need-card {
    background: white; border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px;
    border-top: 3px solid;
  }
  .need-card h4 { font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 7px; }
  .need-card ul { padding-left: 16px; font-size: 12px; }
  .need-card li { margin-bottom: 4px; }

  /* ===== PLANIFICATION ===== */
  .plan-section-title {
    font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; margin-bottom: 6px;
  }
  .plan-pill {
    display: inline-block; padding: 3px 12px; border-radius: 20px; font-size: 11px; font-weight: 700;
    letter-spacing: 0.5px; text-transform: uppercase;
  }
  .plan-pill.college { background: #dbeafe; color: #1e40af; }
  .plan-pill.lycee { background: #ede9fe; color: #5b21b6; }

  .plan-cycle-card {
    background: white; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-bottom: 18px;
  }
  .plan-cycle-header {
    background: var(--ink); color: white; padding: 13px 20px;
    display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }
  .plan-cycle-header .title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; }
  .plan-cycle-header .meta { font-size: 11px; color: #aaa; }
  .plan-cycle-body { padding: 20px; }

  .competence-badge {
    background: #f0f5ff; border: 1.5px solid #bfdbfe; border-radius: 7px; padding: 10px 14px;
    margin-bottom: 10px; font-size: 13px;
  }
  .competence-badge strong { color: var(--accent2); font-family: 'Syne', sans-serif; }

  .chrono-grid {
    display: grid; grid-template-columns: 40px 1fr 1fr 1fr; gap: 0;
    border: 1px solid var(--border); border-radius: 8px; overflow: hidden; font-size: 12px;
    margin-top: 14px;
  }
  .chrono-cell {
    padding: 9px 11px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .chrono-cell:last-child { border-right: none; }
  .chrono-cell.header {
    background: var(--ink); color: white;
    font-family: 'Syne', sans-serif; font-weight: 600; font-size: 10px; letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .chrono-cell.seq-num {
    background: var(--accent2); color: white; font-family: 'Syne', sans-serif;
    font-weight: 800; font-size: 13px; text-align: center; display: flex;
    align-items: center; justify-content: center;
  }
  .chrono-cell.phase-eval { background: #fef3c7; }
  .chrono-cell.phase-acq { background: #f0f5ff; }
  .chrono-cell.phase-bilan { background: #d1fae5; }
  .chrono-row-last .chrono-cell { border-bottom: none; }

  .progress-bar-wrap { margin-top: 10px; }
  .progress-bar-label {
    display: flex; justify-content: space-between; font-size: 11px; color: var(--muted);
    margin-bottom: 4px; font-weight: 600;
  }
  .progress-bar-bg {
    height: 8px; background: var(--stripe); border-radius: 4px; overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%; border-radius: 4px; transition: width 0.6s ease;
  }

  .obj-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 10px; }
  .obj-table th {
    background: #1e293b; color: white; padding: 8px 10px;
    font-family: 'Syne', sans-serif; font-size: 10px; letter-spacing: 0.8px; text-transform: uppercase; text-align: left;
  }
  .obj-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }
  .obj-table tr:nth-child(even) td { background: var(--stripe); }

  .eval-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 12px; margin-top: 14px;
  }
  .eval-item {
    background: white; border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px;
  }
  .eval-item-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; color: var(--accent2); }

  .download-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--stripe); border: 1.5px solid var(--border); border-radius: 6px;
    padding: 7px 14px; font-size: 11px; font-weight: 600; cursor: pointer;
    font-family: 'Syne', sans-serif; text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--ink); transition: all 0.15s; text-decoration: none;
  }
  .download-btn:hover { border-color: var(--accent2); color: var(--accent2); background: #f0f5ff; }

  .aps-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .aps-tab-btn {
    padding: 7px 16px; border-radius: 6px; border: 1.5px solid var(--border);
    font-family: 'Syne', sans-serif; font-weight: 600; font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.5px; cursor: pointer; background: white; transition: all 0.15s; color: var(--ink);
  }
  .aps-tab-btn.active { background: var(--accent2); border-color: var(--accent2); color: white; }
  .aps-tab-btn:not(.active):hover { border-color: var(--accent2); color: var(--accent2); }
  .aps-panel { display: none; }
  .aps-panel.active { display: block; }
</style>

<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;0,9..144,900;1,9..144,400&family=DM+Mono:wght@300;400;500&family=Cabinet+Grotesk:wght@400;500;700;800;900&display=swap" rel="stylesheet">
<style>

/* ── LANDING OVERLAY MACHINERY ── */
#lp {
  position: fixed;
  inset: 0;
  z-index: 9000;
  overflow-y: auto;
  overflow-x: hidden;
  background: #0d1018;
  transition: opacity 0.65s cubic-bezier(.4,0,.2,1),
              transform 0.65s cubic-bezier(.4,0,.2,1);
}
#lp.lp-hiding {
  opacity: 0;
  transform: scale(1.03);
  pointer-events: none;
}
#lp.lp-gone { display: none; }


:root {
  --lp-ink:    #08090c;
  --lp-deep:   #0d1018;
  --lp-surface:#131720;
  --lp-card:   #181d27;
  --lp-border: rgba(255,255,255,0.07);
  --lp-gold:   #d4a843;
  --lp-gold2:  #f0c96a;
  --lp-ember:  #e05c2a;
  --lp-sky:    #4a9eff;
  --lp-green:  #3ecf8e;
  --lp-muted:  #6b7280;
  --lp-light:  #e8e6e0;
  --lp-white:  #f5f3ef;
}

* {box-sizing:border-box;margin:0;padding:0;}
html {scroll-behavior:smooth;}
#lp body {
  font-family:'Cabinet Grotesk',sans-serif;
  background:var(--lp-deep);
  color:var(--lp-white);
  overflow-x:hidden;
}

/* custom cursor désactivé - causait blocage de clics */
#lp #cursor, #lp #cursor-ring { display: none; }

/* ── GRAIN OVERLAY ── */
#lp .grain {
  position:fixed;inset:0;pointer-events:none;z-index:1;
  opacity:0.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat:repeat;background-size:128px 128px;
}

/* ── NAV ── */
#lp nav {
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:18px 48px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(13,16,24,0.85);
  backdrop-filter:blur(20px) saturate(1.4);
  border-bottom:1px solid var(--lp-border);
  animation:slideDown 0.8s cubic-bezier(.17,.67,.35,1) both;
}
@keyframes slideDown{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}
#lp .nav-logo {
  font-family:'Fraunces',serif;font-weight:900;font-size:22px;
  letter-spacing:-1px;display:flex;align-items:center;gap:10px;
}
#lp .nav-logo .accent {color:var(--lp-gold);}
#lp .nav-logo .badge {
  font-family:'DM Mono',monospace;font-size:9px;font-weight:500;
  background:var(--lp-gold);color:var(--lp-deep);
  padding:2px 7px;border-radius:3px;letter-spacing:1.5px;
  text-transform:uppercase;
}
#lp .nav-links {display:flex;gap:32px;align-items:center;}
#lp .nav-links a {
  font-size:13px;font-weight:500;color:var(--lp-muted);text-decoration:none;
  letter-spacing:0.3px;transition:color 0.2s;
}
#lp .nav-links a:hover {color:var(--lp-white);}
#lp .nav-cta {
  background:var(--lp-gold);color:var(--lp-deep);
  padding:10px 22px;border-radius:6px;border:none;cursor:pointer;
  font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:13px;
  letter-spacing:0.3px;text-decoration:none;transition:all 0.2s;
  box-shadow:0 0 0 0 rgba(212,168,67,0.4);
}
#lp .nav-cta:hover {
  background:var(--lp-gold2);transform:translateY(-1px);
  box-shadow:0 8px 32px rgba(212,168,67,0.3);
}

/* ── HERO ── */
#lp .hero {
  position:relative;min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
  background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(212,168,67,0.06) 0%, transparent 70%),
             radial-gradient(ellipse 60% 80% at 90% 50%, rgba(74,158,255,0.04) 0%, transparent 60%),
             var(--lp-deep);
}

/* Orbital SVG background */
#lp .hero-orbs {position:absolute;inset:0;pointer-events:none;}
#lp .hero-orbs svg {width:100%;height:100%;}

/* Animated grid */
#lp .hero-grid {
  position:absolute;inset:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
  background-size:60px 60px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 70%);
}

#lp .hero-content {
  position:relative;z-index:2;
  text-align:center;max-width:920px;padding:120px 24px 80px;
}

#lp .hero-eyebrow {
  display:inline-flex;align-items:center;gap:8px;
  font-family:'DM Mono',monospace;font-size:11px;font-weight:400;
  color:var(--lp-gold);letter-spacing:2.5px;text-transform:uppercase;
  background:rgba(212,168,67,0.08);border:1px solid rgba(212,168,67,0.2);
  padding:6px 16px;border-radius:100px;margin-bottom:32px;
  animation:fadeUp 0.8s 0.3s both;
}
#lp .hero-eyebrow::before {
  content:'';width:6px;height:6px;border-radius:50%;
  background:var(--lp-gold);animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.7)}}

#lp .hero-title {
  font-family:'Fraunces',serif;font-weight:900;
  font-size:clamp(42px,7vw,82px);line-height:1.0;
  letter-spacing:-3px;margin-bottom:28px;
  animation:fadeUp 0.9s 0.5s both;
}
#lp .hero-title em {
  font-style:italic;color:var(--lp-gold);
  background:linear-gradient(135deg,var(--lp-gold),var(--lp-gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
#lp .hero-title .line2 {
  display:block;font-size:clamp(36px,5.5vw,64px);
  color:var(--lp-light);opacity:0.9;
}

#lp .hero-sub {
  font-size:clamp(15px,2vw,18px);color:#9ca3af;line-height:1.7;
  max-width:640px;margin:0 auto 40px;font-weight:400;
  animation:fadeUp 0.9s 0.7s both;
}
#lp .hero-sub strong {color:var(--lp-light);}

#lp .hero-pills {
  display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:48px;
  animation:fadeUp 0.9s 0.85s both;
}
#lp .hero-pill {
  font-size:11px;font-weight:600;letter-spacing:0.5px;
  padding:5px 14px;border-radius:100px;
  border:1px solid rgba(255,255,255,0.1);color:#9ca3af;
  background:rgba(255,255,255,0.03);transition:all 0.2s;
}
#lp .hero-pill:hover {border-color:var(--lp-gold);color:var(--lp-gold);background:rgba(212,168,67,0.06);}

#lp .hero-actions {
  display:flex;gap:14px;justify-content:center;flex-wrap:wrap;
  animation:fadeUp 0.9s 1s both;
}
#lp .btn-hero-primary {
  display:inline-flex;align-items:center;gap:9px;
  background:var(--lp-gold);color:var(--lp-deep);
  padding:16px 34px;border-radius:8px;border:none;cursor:pointer;
  font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:15px;
  letter-spacing:0.2px;text-decoration:none;
  transition:all 0.25s;position:relative;overflow:hidden;
  box-shadow:0 4px 24px rgba(212,168,67,0.25),0 0 0 0 rgba(212,168,67,0.3);
}
#lp .btn-hero-primary::after {
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent);
  opacity:0;transition:opacity 0.2s;
}
#lp .btn-hero-primary:hover {
  background:var(--lp-gold2);transform:translateY(-2px);
  box-shadow:0 12px 40px rgba(212,168,67,0.4),0 0 0 4px rgba(212,168,67,0.15);
}
#lp .btn-hero-primary:hover::after {opacity:1;}
#lp .btn-hero-primary .arrow {transition:transform 0.2s;}
#lp .btn-hero-primary:hover .arrow {transform:translateX(4px);}

#lp .btn-hero-secondary {
  display:inline-flex;align-items:center;gap:8px;
  background:transparent;color:var(--lp-light);
  padding:16px 28px;border-radius:8px;
  border:1.5px solid rgba(255,255,255,0.12);
  font-family:'Cabinet Grotesk',sans-serif;font-weight:600;font-size:15px;
  text-decoration:none;transition:all 0.2s;cursor:pointer;
}
#lp .btn-hero-secondary:hover {border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.05);}

@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}

/* hero scroll indicator */
#lp .scroll-hint {
  position:absolute;bottom:36px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  font-family:'DM Mono',monospace;font-size:10px;color:var(--lp-muted);
  letter-spacing:1.5px;text-transform:uppercase;
  animation:fadeUp 1s 1.4s both;
}
#lp .scroll-hint-line {
  width:1px;height:40px;background:linear-gradient(var(--lp-gold),transparent);
  animation:scrollLine 2s infinite;
}
@keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

/* ── STATS BAR ── */
#lp .stats-bar {
  background:var(--lp-surface);
  border-top:1px solid var(--lp-border);border-bottom:1px solid var(--lp-border);
  padding:32px 48px;
  display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:24px;
}
#lp .stat-item {text-align:center;}
#lp .stat-num {
  font-family:'Fraunces',serif;font-weight:900;font-size:40px;
  color:var(--lp-gold);letter-spacing:-2px;line-height:1;
  display:block;margin-bottom:4px;
}
#lp .stat-label {font-size:12px;color:var(--lp-muted);font-weight:500;letter-spacing:0.3px;}

/* ── SECTION SHARED ── */
#lp section {padding:100px 48px;}
#lp .section-eyebrow {
  font-family:'DM Mono',monospace;font-size:10px;color:var(--lp-gold);
  letter-spacing:3px;text-transform:uppercase;margin-bottom:16px;
  display:flex;align-items:center;gap:10px;
}
#lp .section-eyebrow::before {content:'';flex:none;width:24px;height:1px;background:var(--lp-gold);}
#lp .section-title {
  font-family:'Fraunces',serif;font-weight:900;
  font-size:clamp(32px,4.5vw,54px);line-height:1.05;
  letter-spacing:-2px;margin-bottom:16px;
}
#lp .section-title em {
  font-style:italic;
  background:linear-gradient(135deg,var(--lp-gold),var(--lp-gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
#lp .section-sub {font-size:16px;color:var(--lp-muted);line-height:1.7;max-width:560px;}

#lp .container {max-width:1200px;margin:0 auto;}

/* reveal on scroll */
#lp .reveal {
  opacity:0;transform:translateY(40px);
  transition:opacity 0.8s cubic-bezier(.17,.67,.35,1),transform 0.8s cubic-bezier(.17,.67,.35,1);
}
#lp .reveal.visible {opacity:1;transform:translateY(0);}
#lp .reveal-delay-1 {transition-delay:0.1s;}
#lp .reveal-delay-2 {transition-delay:0.2s;}
#lp .reveal-delay-3 {transition-delay:0.3s;}
#lp .reveal-delay-4 {transition-delay:0.4s;}
#lp .reveal-delay-5 {transition-delay:0.5s;}
#lp .reveal-delay-6 {transition-delay:0.6s;}

/* ── FEATURES GRID ── */
#lp .features-section {background:var(--lp-deep);}
#lp .features-grid {
  display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:2px;background:var(--lp-border);
  border:1px solid var(--lp-border);border-radius:16px;overflow:hidden;
  margin-top:64px;
}
#lp .feature-card {
  background:var(--lp-card);padding:36px 32px;
  position:relative;overflow:hidden;
  transition:background 0.3s;
  cursor:default;
}
#lp .feature-card::before {
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at var(--mx,50%) var(--my,50%), rgba(212,168,67,0.08) 0%, transparent 60%);
  opacity:0;transition:opacity 0.4s;pointer-events:none;
}
#lp .feature-card:hover::before {opacity:1;}
#lp .feature-card:hover {background:#1c2130;}
#lp .feature-icon {
  width:48px;height:48px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;margin-bottom:20px;
  background:rgba(212,168,67,0.08);border:1px solid rgba(212,168,67,0.15);
  transition:transform 0.3s,background 0.3s;
}
#lp .feature-card:hover .feature-icon {transform:scale(1.1);background:rgba(212,168,67,0.15);}
#lp .feature-title {
  font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:17px;
  margin-bottom:10px;color:var(--lp-white);
}
#lp .feature-desc {font-size:13px;color:var(--lp-muted);line-height:1.7;}
#lp .feature-tag {
  display:inline-block;margin-top:16px;
  font-family:'DM Mono',monospace;font-size:9px;
  color:var(--lp-gold);letter-spacing:1.5px;text-transform:uppercase;
  padding:3px 10px;border-radius:100px;
  background:rgba(212,168,67,0.08);border:1px solid rgba(212,168,67,0.15);
}

/* ── WHY SECTION ── */
#lp .why-section {
  background:var(--lp-surface);
  position:relative;overflow:hidden;
}
#lp .why-section::before {
  content:'';position:absolute;top:-200px;right:-200px;
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle, rgba(212,168,67,0.05) 0%, transparent 70%);
  pointer-events:none;
}
#lp .why-layout {
  display:grid;grid-template-columns:1fr 1fr;gap:80px;
  align-items:center;margin-top:64px;
}
@media(max-width:768px){.why-layout{grid-template-columns:1fr;gap:48px;}}
#lp .why-list {display:flex;flex-direction:column;gap:0;}
#lp .why-item {
  display:flex;gap:20px;align-items:flex-start;
  padding:24px 0;
  border-bottom:1px solid var(--lp-border);
  cursor:default;
  transition:padding-left 0.25s;
}
#lp .why-item:hover {padding-left:8px;}
#lp .why-item:last-child {border-bottom:none;}
#lp .why-dot {
  flex-shrink:0;width:40px;height:40px;border-radius:10px;
  background:rgba(212,168,67,0.08);border:1px solid rgba(212,168,67,0.15);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;margin-top:2px;
  transition:background 0.2s,transform 0.2s;
}
#lp .why-item:hover .why-dot {background:rgba(212,168,67,0.18);transform:rotate(5deg);}
#lp .why-text h4 {font-weight:800;font-size:16px;margin-bottom:5px;color:var(--lp-white);}
#lp .why-text p {font-size:13px;color:var(--lp-muted);line-height:1.6;}

/* Visual panel (right side of why) */
#lp .why-visual {
  position:relative;border-radius:20px;overflow:hidden;
  border:1px solid var(--lp-border);
  background:var(--lp-card);
  box-shadow:0 40px 100px rgba(0,0,0,0.5);
}
#lp .why-visual-header {
  background:var(--lp-deep);padding:14px 20px;
  display:flex;align-items:center;gap:8px;
  border-bottom:1px solid var(--lp-border);
}
#lp .wv-dot {width:10px;height:10px;border-radius:50%;}
#lp .why-visual-body {padding:24px;}
#lp .mini-stat-grid {display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
#lp .mini-stat {
  background:var(--lp-surface);border-radius:10px;padding:16px;
  border:1px solid var(--lp-border);
}
#lp .mini-stat-val {
  font-family:'Fraunces',serif;font-weight:900;font-size:28px;color:var(--lp-gold);
  letter-spacing:-1.5px;line-height:1;margin-bottom:3px;
}
#lp .mini-stat-label {font-size:10px;color:var(--lp-muted);font-weight:500;letter-spacing:0.3px;}
#lp .mini-bar-group {display:flex;flex-direction:column;gap:8px;}
#lp .mini-bar-row {display:flex;align-items:center;gap:10px;}
#lp .mini-bar-label {font-size:11px;color:var(--lp-muted);width:80px;flex-shrink:0;}
#lp .mini-bar-bg {flex:1;height:6px;background:rgba(255,255,255,0.06);border-radius:3px;overflow:hidden;}
#lp .mini-bar-fill {height:100%;border-radius:3px;transition:width 1.5s cubic-bezier(.17,.67,.35,1);}
#lp .mini-bar-val {font-size:11px;color:var(--lp-muted);width:30px;text-align:right;}

/* ── APS CAROUSEL ── */
#lp .aps-section {background:var(--lp-deep);padding:100px 0;}
#lp .aps-header {padding:0 48px;margin-bottom:56px;}
#lp .aps-track-wrap {overflow:hidden;position:relative;}
#lp .aps-track-wrap::before, #lp .aps-track-wrap::after {
  content:'';position:absolute;top:0;bottom:0;width:120px;z-index:2;pointer-events:none;
}
#lp .aps-track-wrap::before {left:0;background:linear-gradient(90deg,var(--lp-deep),transparent);}
#lp .aps-track-wrap::after {right:0;background:linear-gradient(-90deg,var(--lp-deep),transparent);}
#lp .aps-track {
  display:flex;gap:16px;padding:8px 48px;
  animation:scrollTrack 28s linear infinite;
  width:max-content;
}
#lp .aps-track:hover {animation-play-state:paused;}
@keyframes scrollTrack{from{transform:translateX(0)}to{transform:translateX(-50%)}}
#lp .aps-card {
  flex-shrink:0;width:200px;
  background:var(--lp-card);border:1px solid var(--lp-border);border-radius:14px;
  padding:24px 20px;text-align:center;
  transition:all 0.3s;cursor:default;
}
#lp .aps-card:hover {
  border-color:rgba(212,168,67,0.3);transform:translateY(-6px);
  background:#1c2130;box-shadow:0 20px 60px rgba(0,0,0,0.4);
}
#lp .aps-emoji {font-size:36px;margin-bottom:12px;display:block;}
#lp .aps-name {font-weight:800;font-size:14px;margin-bottom:4px;}
#lp .aps-cat {font-size:11px;color:var(--lp-muted);font-family:'DM Mono',monospace;letter-spacing:0.5px;}

/* ── TESTIMONIALS ── */
#lp .testimonials-section {background:var(--lp-surface);}
#lp .testimonials-grid {
  display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;margin-top:56px;
}
#lp .testimonial-card {
  background:var(--lp-card);border:1px solid var(--lp-border);border-radius:16px;
  padding:32px 28px;position:relative;
  transition:transform 0.3s,border-color 0.3s;cursor:default;
}
#lp .testimonial-card:hover {transform:translateY(-4px);border-color:rgba(212,168,67,0.2);}
#lp .testimonial-card::before {
  content:'❝';position:absolute;top:20px;right:24px;
  font-size:48px;color:rgba(212,168,67,0.08);font-family:'Fraunces',serif;line-height:1;
}
#lp .test-stars {color:var(--lp-gold);font-size:14px;margin-bottom:16px;letter-spacing:2px;}
#lp .test-text {font-size:14px;color:#c9c5bc;line-height:1.75;margin-bottom:24px;font-style:italic;}
#lp .test-author {display:flex;align-items:center;gap:12px;}
#lp .test-avatar {
  width:40px;height:40px;border-radius:50%;
  background:linear-gradient(135deg,var(--lp-gold),var(--lp-ember));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:15px;color:var(--lp-deep);flex-shrink:0;
}
#lp .test-name {font-weight:700;font-size:14px;}
#lp .test-role {font-size:11px;color:var(--lp-muted);}

/* ── CTA FINAL ── */
#lp .cta-section {
  background:var(--lp-deep);text-align:center;
  position:relative;overflow:hidden;
  padding:120px 48px;
}
#lp .cta-section::before {
  content:'';position:absolute;top:50%;left:50%;
  width:800px;height:400px;border-radius:50%;
  background:radial-gradient(ellipse, rgba(212,168,67,0.08) 0%, transparent 70%);
  transform:translate(-50%,-50%);pointer-events:none;
}
#lp .cta-section::after {
  content:'';position:absolute;top:0;left:0;right:0;
  height:1px;background:linear-gradient(90deg,transparent,var(--lp-gold),transparent);
}
#lp .cta-section .section-title {font-size:clamp(36px,5vw,60px);margin-bottom:20px;}
#lp .cta-section .section-sub {margin:0 auto 48px;font-size:17px;}
#lp .cta-logos {
  display:flex;justify-content:center;align-items:center;gap:32px;
  flex-wrap:wrap;margin-top:60px;opacity:0.4;
}
#lp .cta-logo-item {
  font-family:'DM Mono',monospace;font-size:11px;color:var(--lp-muted);
  letter-spacing:2px;text-transform:uppercase;
}

/* ── FOOTER ── */
#lp footer {
  background:var(--lp-ink);border-top:1px solid var(--lp-border);
  padding:36px 48px;
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:16px;
}
#lp .footer-logo {
  font-family:'Fraunces',serif;font-weight:900;font-size:18px;letter-spacing:-1px;
}
#lp .footer-logo span {color:var(--lp-gold);}
#lp .footer-copy {font-size:12px;color:var(--lp-muted);}
#lp .footer-badge {
  font-family:'DM Mono',monospace;font-size:9px;color:var(--lp-gold);
  letter-spacing:2px;text-transform:uppercase;
  background:rgba(212,168,67,0.08);border:1px solid rgba(212,168,67,0.2);
  padding:4px 12px;border-radius:100px;
}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  #lp nav{padding:16px 24px;}
  #lp .nav-links{display:none;}
  #lp section{padding:72px 24px;}
  #lp .stats-bar{padding:24px;}
  #lp .aps-header{padding:0 24px;}
  #lp footer{padding:28px 24px;}
  #lp .cta-section{padding:80px 24px;}
}
@media(max-width:600px){
  #lp .hero-title{font-size:38px;letter-spacing:-1.5px;}
}

/* ── ANIMATED ORBITAL ── */
#lp .orbital-container {
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:900px;height:900px;pointer-events:none;
}
#lp .orb {
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  border:1px solid;border-radius:50%;
  animation:rotate linear infinite;
}
#lp .orb-1 {width:300px;height:300px;border-color:rgba(212,168,67,0.06);animation-duration:20s;}
#lp .orb-2 {width:500px;height:500px;border-color:rgba(74,158,255,0.04);animation-duration:35s;animation-direction:reverse;}
#lp .orb-3 {width:700px;height:700px;border-color:rgba(212,168,67,0.03);animation-duration:50s;}
#lp .orb-dot {
  position:absolute;width:6px;height:6px;border-radius:50%;
  background:var(--lp-gold);top:0;left:50%;margin-left:-3px;margin-top:-3px;
}
