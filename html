function autoTotalTime() {
  const cfg = getConfig();
  const sexe = document.getElementById('new-sexe').value;
  const dist = sexe === 'M' ? DIST_G : DIST_F;
  const tours = Math.round(dist / cfg.piste);
  let total = 0;
  let allFilled = true;
  for (let i = 1; i <= tours; i++) {
    const val = document.getElementById('new-lap-' + i)?.value || '';
    const s = parseTime(val);
    if (s === null) { allFilled = false; break; }
    total += s;
  }
  if (allFilled && total > 0) {
    document.getElementById('new-total-time').value = formatTime(total);
  }
}

// ============================================================
//  TIME HELPERS
// ============================================================
function parseTime(str) {
  if (!str || !str.trim()) return null;
  str = str.trim();
  if (str.includes(':')) {
    const parts = str.split(':');
    if (parts.length === 2) {
      const m = parseInt(parts[0]);
      const s = parseFloat(parts[1]);
      if (isNaN(m) || isNaN(s)) return null;
      return m * 60 + s;
    }
  }
  const n = parseFloat(str);
  return isNaN(n) ? null : n;
}

function formatTime(seconds) {
  if (seconds === null || isNaN(seconds) || seconds === Infinity) return '—';
  const m = Math.floor(seconds / 60);
  const s = Math.round(seconds % 60);
  return m + ':' + String(s).padStart(2, '0');
}

// ============================================================
//  SCORING ENGINE
// ============================================================
function scorePerformance(niveau, sexe, totalSec) {
  if (totalSec === null) return null;
  const scale = PERF_SCALES[niveau]?.[sexe];
  if (!scale) return null;
  for (const [threshold, pts] of scale) {
    if (totalSec <= threshold) return pts;
  }
  return 0.3;
}

function scoreRegularite(niveau, sommeEcarts) {
  if (sommeEcarts === null) return null;
  const scale = REG_SCALES[niveau];
  if (!scale) return null;
  for (const [threshold, pts] of scale) {
    if (sommeEcarts <= threshold) return pts;
  }
  return 0.6;
}

function scoreCible(statut) {
  return CIBLE_SCORES[statut] || 0;
}

function computeStudent(s, cfg) {
  const dist = s.sexe === 'M' ? DIST_G : DIST_F;
  const tours = Math.round(dist / cfg.piste);
  const vitesse_ms = s.vma / 3.6;
  const tempsCibleTour = cfg.piste / vitesse_ms;

  let sommeEcarts = 0;
  let allLaps = true;
  const lapTimes = [];
  for (let i = 0; i < tours; i++) {
    const t = s.laps[i] !== undefined ? s.laps[i] : null;
    lapTimes.push(t);
    if (t === null) { allLaps = false; }
    else { sommeEcarts += Math.abs(t - tempsCibleTour); }
  }
  if (!allLaps) { sommeEcarts = null; }

  let notePerf = s.notePerf;
  if (notePerf === null) {
    const totalSec = lapTimes.every(t => t !== null) ? lapTimes.reduce((a,b)=>a+b,0) : null;
    notePerf = scorePerformance(cfg.niveau, s.sexe, totalSec);
  }

  const noteReg = allLaps ? scoreRegularite(cfg.niveau, sommeEcarts) : null;
  const noteCible = scoreCible(s.cible);

  let total = null;
  if (notePerf !== null && noteReg !== null) {
    total = (notePerf || 0) + (noteReg || 0) + noteCible;
    total = Math.min(20, Math.round(total * 10) / 10);
  }

  let niveau = '—';
  if (total !== null) {
    if (total > 16) niveau = 'A';
    else if (total >= 11) niveau = 'B';
    else niveau = 'C';
  }

  return {
    tempsCibleTour, lapTimes, sommeEcarts,
    notePerf, noteReg, noteCible,
    total, niveau, tours, dist
  };
}

