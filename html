function importCSV(event) {
  const file = event.target.files[0]; if (!file) return;
  const cfg = getConfig();
  const reader = new FileReader();
  reader.onload = function(e) {
    const text = e.target.result;
    const lines = text.split('\n').filter(l => l.trim());
    let count = 0;
    lines.forEach((line, idx) => {
      if (idx === 0 && line.toLowerCase().includes('nom')) return;
      const parts = line.split(',').map(p => p.trim());
      if (parts.length < 5) return;
      const nom = parts[0]; const sexe = parts[1].toUpperCase() === 'F' ? 'F' : 'M';
      const vma = parseFloat(parts[2]);
      const cible = ['FT','FP','AB'].includes(parts[4].toUpperCase()) ? parts[4].toUpperCase() : 'FT';
      if (!nom || isNaN(vma)) return;
      const dist = sexe === 'M' ? DIST_G : DIST_F;
      const tours = Math.round(dist / cfg.piste);
      const laps = [];
      for (let i = 0; i < tours; i++) { laps.push(parts[5+i] ? parseTime(parts[5+i]) : null); }
      students.push({ id: ++studentIdCounter, nom, sexe, vma, notePerf: null, cible, laps });
      count++;
    });
    document.getElementById('csv-feedback').textContent = `✅ ${count} élève(s) importé(s).`;
    renderTable(); updateDashboard();
  };
  reader.readAsText(file);
}

function downloadCSVTemplate() {
  const cfg = getConfig();
  const toursG = Math.round(DIST_G / cfg.piste);
  const lapHeaders = Array.from({length: Math.max(toursG, Math.round(DIST_F/cfg.piste))}, (_,i) => 'Temps_T'+(i+1)).join(',');
  const content = `Nom,Sexe(M/F),VMA_kmh,NotePerf_sur6,StatutCible(FT/FP/AB),${lapHeaders}\nAhmed Alaoui,M,12.5,,FT,1:50,1:52,1:48,1:55,1:50\n`;
  const blob = new Blob([content], {type:'text/csv;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'modele_course_duree.csv'; a.click();
}

function exportCSV() {
  if (students.length === 0) { alert('Aucun élève à exporter.'); return; }
  const cfg = getConfig();
  const lines = ['Nom,Sexe,VMA,NotePerf,NoteRegularite,NoteCible,NoteFinale,Niveau,SommeEcarts,StatutCible'];
  students.forEach(s => {
