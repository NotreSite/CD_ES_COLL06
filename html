function generateDiagnostic(s, res, cfg) {
  const diagEl = document.getElementById('modal-diagnostic');
  let diagText = ''; let remList = [];
  const lapTimes = res.lapTimes.filter(t => t !== null);
  let tendance = '';
  if (lapTimes.length >= 2) {
    const firstHalf = lapTimes.slice(0, Math.floor(lapTimes.length/2));
    const lastHalf = lapTimes.slice(Math.ceil(lapTimes.length/2));
    const avgFirst = firstHalf.reduce((a,b)=>a+b,0)/firstHalf.length;
    const avgLast = lastHalf.reduce((a,b)=>a+b,0)/lastHalf.length;
    if (avgLast - avgFirst > 5) tendance = 'décélérant';
    else if (avgLast - avgFirst < -5) tendance = 'accélérant';
    else tendance = 'régulier';
  }

  if (res.niveau === 'A') {
    diagText = `L'élève ${s.nom} démontre une maîtrise parfaite...`;
    remList = ['Proposer un objectif supérieur (+0.5 VMA).', 'Faire participer comme tuteur.'];
  } else if (res.niveau === 'B') {
    diagText = `L'élève ${s.nom} est en cours d'acquisition...`;
    remList = ['Travailler avec bips sonores.', 'Utiliser des leaders d\'allure.'];
  } else {
    diagText = `L'élève ${s.nom} présente une gestion anarchique...`;
    remList = ['Vérifier la VMA de base.', 'Brider la vitesse sur les premiers tours.'];
  }

  diagEl.innerHTML = `
    <div class="diag-box"><strong>🩺 Diagnostic :</strong> ${diagText}</div>
    <div class="rem-box"><strong>🎯 Conseils :</strong><ul>${remList.map(r=>`<li>${r}</li>`).join('')}</ul></div>
  `;
}

